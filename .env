# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=dev

# Generate with: php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=changeme_generate_a_32_byte_hex_string

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=root
MONGO_APP_USER=ets_user
MONGO_APP_PASSWORD=ets_password
MONGO_DB=ets_language_exams

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate keys with: make jwt-keys  (see Makefile)
JWT_PASSPHRASE=changeme_generate_a_strong_passphrase
JWT_TTL=3600

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api
NODE_ENV=development

# ─── Nginx ───────────────────────────────────────────────────────────────────
HTTP_PORT=80

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOW_ORIGIN=^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$
